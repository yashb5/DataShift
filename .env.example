# DataShift Configuration

# Application
DATASHIFT_APP_NAME=DataShift
DATASHIFT_DEBUG=true

# Database (SQLite for development)
DATASHIFT_DATABASE_URL=sqlite+aiosqlite:///./data/datashift.db
DATASHIFT_DATABASE_ECHO=true

# PostgreSQL example:
# DATASHIFT_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/datashift

# MySQL example:
# DATASHIFT_DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/datashift

# Encryption (use a strong key in production - must be 16, 24, or 32 bytes for AES)
DATASHIFT_ENCRYPTION_KEY=datashift-secret-key-16

# Server
DATASHIFT_SERVER_PORT=8080

# Metrics
DATASHIFT_METRICS_ENABLED=true
